{
  "name": "codex-whatsapp",
  "version": "0.4.3-hardened.4",
  "private": true,
  "type": "module",
  "description": "Hardened, send-only Codex WhatsApp relay with local QR authentication.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "whatsapp:auth": "node ./plugins/whatsapp-relay/scripts/whatsapp-auth.mjs",
    "whatsapp:mcp": "node ./plugins/whatsapp-relay/scripts/mcp-server.mjs",
    "whatsapp:status": "node ./plugins/whatsapp-relay/scripts/whatsapp-status.mjs",
    "check": "node --check ./plugins/whatsapp-relay/scripts/*.mjs",
    "test": "node --test ./plugins/whatsapp-relay/scripts/*.test.mjs"
  },
  "dependencies": {
    "@hapi/boom": "10.0.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "pino": "9.14.0",
    "qrcode-terminal": "0.12.0",
    "zod": "4.4.3"
  },
  "overrides": {
    "@whiskeysockets/baileys": {
      "link-preview-js": "4.0.1"
    }
  }
}
