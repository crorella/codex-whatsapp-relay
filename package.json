{
  "name": "codex-whatsapp",
  "version": "0.4.3-hardened.9-experimental.2",
  "private": true,
  "type": "module",
  "description": "Experimental hardened Codex WhatsApp relay using a local whatsmeow sidecar.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "whatsapp:auth": "node ./plugins/whatsapp-relay/scripts/whatsapp-auth.mjs",
    "whatsapp:mcp": "node ./plugins/whatsapp-relay/scripts/mcp-server.mjs",
    "whatsapp:status": "node ./plugins/whatsapp-relay/scripts/whatsapp-status.mjs",
    "whatsapp:service": "node ./plugins/whatsapp-relay/scripts/relay-service.mjs",
    "whatsapp:service:install": "node ./plugins/whatsapp-relay/scripts/install-relay-service.mjs",
    "build:whatsmeow": "go build -C ./plugins/whatsapp-relay/whatsmeow-sidecar -o ../bin/whatsmeow-sidecar ./cmd/whatsmeow-sidecar",
    "test:go": "go test -C ./plugins/whatsapp-relay/whatsmeow-sidecar ./...",
    "check": "node --check ./plugins/whatsapp-relay/scripts/*.mjs",
    "test": "node --test ./plugins/whatsapp-relay/scripts/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "qrcode-terminal": "0.12.0",
    "zod": "4.4.3"
  }
}
